[gd_resource type="Resource" script_class="NovelTextResource" format=3]

[ext_resource type="Script" uid="uid://cqo4s66ui3yf6" path="res://data/definitions/novel_text_resource.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
text = "人間を壊す悪夢\n少しだけ力の使い方を覚えた時期に訪れる悪夢。力を弱めればいいと気づくが、分散しても結局壊してしまう。力の使い方を理解したと勘違いするこの時期が一番恐ろしい。この時期は人間と触れ合うのは禁止されているのに、自分の制御を過信して人間と出会う。結果はみんな同じ。全身が血まみれになり、絶叫し、泣き叫ぶ。あなたが悪いの。あなたが信じたのが悪い。もっと自分を理解していればよかったのに。最初から最後まで全部あなたのせいだよ"
