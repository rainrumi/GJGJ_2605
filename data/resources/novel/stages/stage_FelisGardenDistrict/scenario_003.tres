[gd_resource type="Resource" script_class="NovelTextResource" format=3]

[ext_resource type="Script" uid="uid://cqo4s66ui3yf6" path="res://data/definitions/novel/novel_text_resource.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
text = "生活リズムが治らない悪夢\n起きるのは夕方、眠るのは朝。\nもう何度目だろう。夜は体がよく動くからしょうがない。夜は夜空がきれいで友人たちもにぎわっている。朝に起きなくてもいいんだ。僕はもう成功した大人だから。"
