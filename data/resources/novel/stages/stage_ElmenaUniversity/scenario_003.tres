[ext_resource type="Script" uid="uid://cqo4s66ui3yf6" path="res://data/definitions/novel/novel_text_resource.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
text = "最終締め切りに襲われる悪夢\nこれを落としたら落第レベルの研究論文の提出に追われる。どんな方法でもよいのでこれを解決しなければならない。"
