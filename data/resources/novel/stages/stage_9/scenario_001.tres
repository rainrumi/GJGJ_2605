[gd_resource type="Resource" script_class="NovelTextResource" format=3]

[ext_resource type="Script" uid="uid://cqo4s66ui3yf6" path="res://data/definitions/novel_text_resource.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
text = "すぐにものを壊す悪夢\n人間が作るものは脆い。\n成長期は力のコントロールができずにいろんなものを壊しがち。間違えて大切なものを壊してしまう悪夢。ああ、もう同じものは手に入らないのに"
