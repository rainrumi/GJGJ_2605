[gd_resource type="Resource" script_class="NovelTextResource" format=3]

[ext_resource type="Script" uid="uid://cqo4s66ui3yf6" path="res://data/definitions/novel/novel_text_info.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
text = "多くの叱責を受ける悪夢\n世の中の人々におおくの悪口をかけられて精神が病んでしまった。自分に自信を無くし、いつか他人からの悪口に対してダメージを受けなくなってしまった。"
