[gd_resource type="Resource" script_class="NovelTextResource" format=3]

[ext_resource type="Script" uid="uid://cqo4s66ui3yf6" path="res://data/info/novel/novel_text_info.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
text = "みんなでやれば怖くない悪夢\n前の場所よりもひどく、大勢の人と妖精が働いている場所を見つける。寝ているものもちらほらいて、夜なのに騒がしい。"
