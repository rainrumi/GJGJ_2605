[gd_resource type="Resource" script_class="NovelTextResource" format=3]

[ext_resource type="Script" uid="uid://cqo4s66ui3yf6" path="res://data/definitions/novel/novel_text_info.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
text = "依存する悪夢\n妖精が生まれるにはいくつかの手順が必要になる。大樹リランの実った木の実が地面に落ち、土の中に染みたエキスがイリユ洞窟に住むバクが放出する成分と混ざり合うことで妖精の卵が生まれる。30年前、これを知った政府はバクを飼育して生まれる妖精の能力をコントロールしようと試みた。結果は大失敗だった。バクはとても繊細で、人間が管理できるような生物ではなかった。これによりバクと妖精が大激減し、人類は孤独な運命を歩むことになりかけた。"
