[ext_resource type="Script" path="res://data/definitions/nightmare_skill_definition.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
skill_id = 11
category = "消化順・連鎖反応系（悪夢が消化された時、または他の悪夢が消化された時に反応する系統。）"
display_name = "悪夢名"
description = "消化されたとき、消化された順番が奇数でない場合、最大HP50%を最大HPとしてHP100%で復活する。（同時消化の場合は余剰ダメ量＞設置順で消化順が決定される）"
