[resource]
script = ExtResource("1_script")
skill_id = 4
category = "夢の花系統"
display_name = "夢の花名"
main_description = "HPがゼロになったとき、回復するHP+50%。効果が発動するたびに回復量は10%減少する（最小0%）"
sub_description = "シールド４層,HP1,T型マス\n胃袋に存在時HPがゼロになっても時間経過ペナルティが発生しない。この効果が発動するとシールドがすべて消滅する。"
