# Copy to .agent/godot-agent.env and customize for this repository.
# Do not commit machine-specific absolute paths unless the repository intends to share them.

# Godot editor binary. Examples: godot, godot4, godot-mono, /Applications/Godot.app/Contents/MacOS/Godot
# GODOT_BIN=godot

# Commands are executed from the project root by a shell.
# GODOT_FORMAT_CHECK_COMMAND="gdformat --check ."
# GODOT_LINT_COMMAND="gdlint ."
# GODOT_TEST_COMMAND="godot --headless --path . -s addons/gut/gut_cmdln.gd"

# Optional runtime smoke target. If omitted, the script uses the configured Main Scene when present.
# GODOT_SMOKE_SCENE="res://tests/smoke/smoke_test.tscn"
# GODOT_SMOKE_FRAMES=5

# Regex for known, explicitly accepted log lines. Keep this narrow.
# GODOT_ALLOWED_LOG_REGEX="Known harmless message from a third-party addon"
